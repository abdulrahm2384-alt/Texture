# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# DATABASE CONFIGURATION (MySQL / MariaDB)
# Leave these blank/unconfigured to use the automatic local db.json file-based fallback during development.
# Fill these in on your production DirectAdmin Node.js environment.
DB_HOST=""
DB_PORT="3306"
DB_NAME=""
DB_USER=""
DB_PASSWORD=""

# DIRECTADMIN SMTP EMAIL SERVICE (Used only for admin OTP verification)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"

# SECURE ADMIN EMAIL (Authorized administrative account email address)
ADMIN_EMAIL="admin@oluwashola-atelier.com"

# JWT CRYPTOGRAPHIC SIGNATURE SECRET
# A secure, long, random string used for cryptographically signing session tokens.
# Keep this secret safe and do not expose it.
JWT_SECRET=""
